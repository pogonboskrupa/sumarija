<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SumarijaNative" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:statusBarColor">#1E3A5F</item>
        <item name="android:navigationBarColor">#1E3A5F</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
    <style name="Theme.SumarijaNative.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#1E3A5F</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.SumarijaNative</item>
    </style>
</resources>
